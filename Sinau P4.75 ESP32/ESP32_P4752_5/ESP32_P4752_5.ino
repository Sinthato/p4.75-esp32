/**************** VARIABLE KONTROL ****************/
int page = 1; 
int stateRolling = 0; 
int scrollX = WIDTH;
int scrollY = 16;
int wordIndex = 0;
String kataAktif = "";
unsigned long timerAnimasi = 0;
unsigned long timerTahan = 0;

/**************** FUNGSI DASAR ****************/
void clearBuffer() { memset(buffer, 0, sizeof(buffer)); }

void drawChar(char c, int x, int y) {
  const uint8_t* f = nullptr;
  if (c >= 'A' && c <= 'Z') f = font_alfabet[c - 'A'];
  else if (c >= '0' && c <= '9') f = font_angka[c - '0'];
  if (f == nullptr) return;

  for (int col = 0; col < 7; col++) {
    int cx = x + col;
    if (cx >= 0 && cx < WIDTH) {
      uint8_t a = f[col * 2];
      uint8_t b = f[col * 2 + 1];
      for (int bit = 0; bit < 8; bit++) {
        int cyA = y + bit;
        int cyB = y + bit + 8;
        if (cyA >= 0 && cyA < HEIGHT) buffer[cyA][cx] = !(a & (1 << (7 - bit)));
        if (cyB >= 0 && cyB < HEIGHT) buffer[cyB][cx] = !(b & (1 << (7 - bit)));
      }
    }
  }
}

void drawString(String t, int x, int y) {
  for (int i = 0; i < t.length(); i++) {
    if (t[i] == '#') break;
    drawChar(t[i], x + (i * 8), y);
  }
}

int getLengthNoHash(String t) {
  int l = 0;
  for (int i = 0; i < t.length(); i++) { if (t[i] == '#') break; l++; }
  return l;
}

String pecahKata() {
  String hasil = "";
  while (wordIndex < pesanRolling.length()) {
    char c = pesanRolling[wordIndex];
    wordIndex++;
    if (c == ' ' || c == '#') {
      if (hasil.length() > 0) return hasil;
      if (c == '#') { wordIndex = 0; return "EOF"; }
      continue;
    }
    hasil += c;
  }
  wordIndex = 0; return "EOF";
}

/**************** HUB75 SCANNING ****************/
byte scanOrder[8] = {1, 3, 5, 7, 0, 2, 4, 6};
void scanLayer(bool bawah) {
  digitalWrite(DD, bawah);
  for (int i = 0; i < 8; i++) {
    int row = scanOrder[i];
    digitalWrite(OE, HIGH);
    digitalWrite(A, row & 1); digitalWrite(B, (row >> 1) & 1); digitalWrite(C, (row >> 2) & 1);
    for (int col = 0; col < WIDTH; col++) {
      digitalWrite(DATA_KIRI, buffer[row + (bawah ? 8 : 0)][col]);
      digitalWrite(DATA_KANAN, buffer[row + (bawah ? 8 : 0)][col]);
      digitalWrite(CLK, HIGH); digitalWrite(CLK, LOW);
    }
    digitalWrite(LAT, HIGH); delayMicroseconds(1); digitalWrite(LAT, LOW);
    digitalWrite(OE, LOW); delayMicroseconds(80); 
  }
}

/**************** MAIN LOOP ****************/
void setup() {
  pinMode(DATA_KIRI, OUTPUT); pinMode(DATA_KANAN, OUTPUT);
  pinMode(CLK, OUTPUT); pinMode(LAT, OUTPUT); pinMode(OE, OUTPUT);
  pinMode(A, OUTPUT); pinMode(B, OUTPUT); pinMode(C, OUTPUT); pinMode(DD, OUTPUT);
  digitalWrite(OE, HIGH);
}

void loop() {
  if (millis() - timerAnimasi > 35) {
    timerAnimasi = millis();
    clearBuffer();

    if (page == 1) {
      // MODE RUNNING TEXT (Pesan 1 utuh)
      drawString(pesanRunning, scrollX, 0);
      scrollX--;
      if (scrollX < (getLengthNoHash(pesanRunning) * -8)) {
        page = 2;
        wordIndex = 0;
        kataAktif = pecahKata();
        scrollY = 16;
        stateRolling = 0;
      }
    } 
    else if (page == 2) {
      // MODE ROLLING PER KATA (Pesan 2 dipotong)
      int centerX = (WIDTH / 2) - (kataAktif.length() * 4);
      
      if (stateRolling == 0) { // Muncul
        drawString(kataAktif, centerX, scrollY);
        scrollY--;
        if (scrollY <= 0) { scrollY = 0; stateRolling = 1; timerTahan = millis(); }
      } 
      else if (stateRolling == 1) { // Tahan 1 Detik
        drawString(kataAktif, centerX, 0);
        if (millis() - timerTahan > 1000) { stateRolling = 2; }
      } 
      else if (stateRolling == 2) { // Naik
        drawString(kataAktif, centerX, scrollY);
        scrollY--;
        if (scrollY < -16) {
          kataAktif = pecahKata();
          if (kataAktif == "EOF") {
            page = 1; 
            scrollX = WIDTH;
          } else {
            scrollY = 16;
            stateRolling = 0;
          }
        }
      }
    }
  }

  scanLayer(true);
  scanLayer(false);
}